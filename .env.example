# Skillsgem environment variables
# Copy this file to .env for local development. Never commit your real .env.
# On Render, set these in the dashboard (Environment tab) — render.yaml handles
# most of them automatically; only ADMIN_TOKEN needs you to type a value.

# Port the server listens on. Render injects this automatically (usually 10000).
# Locally, leave as 5000 unless you have a conflict.
PORT=5000

# Where the SQLite database file lives.
# Render: /data/data.db  (mounted persistent disk — set in render.yaml)
# Local:  leave blank to use ./data.db in the project root
DATABASE_PATH=

# Admin panel password. Change this to something only you know.
# You will need this to access /#/admin on your live site.
ADMIN_TOKEN=change-me-to-something-secret

# Node environment. Leave as production on Render.
NODE_ENV=development
